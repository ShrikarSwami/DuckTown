[node name="Title" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.9, 0.4, 1)
theme_override_font_sizes/font_size = 36
text = "Welcome to DuckTown"
horizontal_alignment = 1

[node name="Separator1" type="Control" parent="MarginContainer/VBoxContainer"]
custom_minimum_size = Vector2(0, 20)
layout_mode = 2

[node name="StoryText" type="RichTextLabel" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
size_flags_vertical = 3
theme_override_colors/default_color = Color(0.9, 0.9, 0.9, 1)
theme_override_font_sizes/normal_font_size = 20
bbcode_enabled = true
text = "[center]The Mayor has announced a grand town party to celebrate DuckTown's anniversary!

But there's a problem... [b]three crucial approvals[/b] are needed to make it happen:

[color=yellow]🥖 The Baker[/color] must provide food
[color=yellow]🎨 The Merchant[/color] must handle decorations  
[color=yellow]🛡️ The Guard[/color] must ensure safety

Your mission: [b]Talk to the townspeople, spread helpful information, and build trust[/b] with these three key NPCs.

[i]Hint: What you say matters. Choose your words carefully, and pay attention to rumors spreading through town...[/i][/center]"
fit_content = true
scroll_active = false

[node name="Separator2" type="Control" parent="MarginContainer/VBoxContainer"]
custom_minimum_size = Vector2(0, 20)
layout_mode = 2

[node name="GameplayHints" type="RichTextLabel" parent="MarginContainer/VBoxContainer"]
custom_minimum_size = Vector2(0, 120)
layout_mode = 2
theme_override_colors/default_color = Color(0.7, 0.8, 0.9, 1)
theme_override_font_sizes/normal_font_size = 18
bbcode_enabled = true
text = "[center][b]Controls:[/b]
WASD or Arrow Keys = Move
E = Interact with NPCs
D = Toggle Debug Overlay (shows trust levels & rumors)[/center]"
fit_content = true
scroll_active = false

[node name="Separator3" type="Control" parent="MarginContainer/VBoxContainer"]
custom_minimum_size = Vector2(0, 20)
layout_mode = 2

[node name="ContinuePrompt" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 0.7)
theme_override_font_sizes/font_size = 18
