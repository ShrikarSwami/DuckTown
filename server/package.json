{
  "name": "duck-party-backend",
  "version": "0.1.0",
  "description": "Backend proxy for Duck Party Rumor Game - relays requests to Google Gemini API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "reset-port": "lsof -tiTCP:8080 -sTCP:LISTEN | xargs kill -9 2>/dev/null || true",
